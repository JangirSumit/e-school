<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SchoolManagement.Views.StudentsPage"
             Title="Students">
    <Grid RowDefinitions="Auto,*">
        <Button Grid.Row="0" Text="Add Student" Command="{Binding AddStudentCommand}" Margin="10"/>
        <CollectionView Grid.Row="1" ItemsSource="{Binding Students}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="10,5" Padding="10">
                        <VerticalStackLayout>
                            <Label Text="{Binding RollNumber}" FontAttributes="Bold"/>
                            <Label Text="{Binding Class}"/>
                            <Label Text="{Binding Section}"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
