<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:m="clr-namespace:UraniumUI.Icons.MaterialIcons;assembly=UraniumUI.Icons.MaterialIcons"
             x:Class="SchoolManagement.Views.DashboardPage"
             Title="Dashboard"
             BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Frame BackgroundColor="{StaticResource Primary}" CornerRadius="15" Padding="20" HasShadow="True">
                <HorizontalStackLayout Spacing="15">
                    <Image Source="{FontImageSource FontFamily=MaterialOutlined, Glyph={x:Static m:MaterialOutlined.Account_circle}, Size=50, Color=White}" 
                           HeightRequest="50" WidthRequest="50"/>
                    <VerticalStackLayout VerticalOptions="Center">
                        <Label Text="{Binding UserName, StringFormat='Welcome, {0}'}" FontSize="20" FontAttributes="Bold" TextColor="White"/>
                        <Label Text="School Administrator" FontSize="14" TextColor="White" Opacity="0.8"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Frame>
            
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="15" RowSpacing="15" Margin="0,10,0,0">
                <Frame Grid.Row="0" Grid.Column="0" Padding="0" HasShadow="True" CornerRadius="15" 
                       BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                    <Button Text="Students" Command="{Binding NavigateToStudentsCommand}" 
                            BackgroundColor="Transparent" 
                            TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" 
                            HeightRequest="100" CornerRadius="15">
                        <Button.ImageSource>
                            <FontImageSource FontFamily="MaterialOutlined" Glyph="{x:Static m:MaterialOutlined.School}" Size="40" 
                                           Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                        </Button.ImageSource>
                    </Button>
                </Frame>
                
                <Frame Grid.Row="0" Grid.Column="1" Padding="0" HasShadow="True" CornerRadius="15" 
                       BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                    <Button Text="Faculties" Command="{Binding NavigateToFacultiesCommand}" 
                            BackgroundColor="Transparent" 
                            TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" 
                            HeightRequest="100" CornerRadius="15">
                        <Button.ImageSource>
                            <FontImageSource FontFamily="MaterialOutlined" Glyph="{x:Static m:MaterialOutlined.People}" Size="40" 
                                           Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                        </Button.ImageSource>
                    </Button>
                </Frame>
                
                <Frame Grid.Row="1" Grid.Column="0" Padding="0" HasShadow="True" CornerRadius="15" 
                       BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                    <Button Text="Attendance" Command="{Binding NavigateToAttendanceCommand}" 
                            BackgroundColor="Transparent" 
                            TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" 
                            HeightRequest="100" CornerRadius="15">
                        <Button.ImageSource>
                            <FontImageSource FontFamily="MaterialOutlined" Glyph="{x:Static m:MaterialOutlined.Check_circle}" Size="40" 
                                           Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                        </Button.ImageSource>
                    </Button>
                </Frame>
                
                <Frame Grid.Row="1" Grid.Column="1" Padding="0" HasShadow="True" CornerRadius="15" 
                       BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                    <Button Text="Marks" Command="{Binding NavigateToMarksCommand}" 
                            BackgroundColor="Transparent" 
                            TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" 
                            HeightRequest="100" CornerRadius="15">
                        <Button.ImageSource>
                            <FontImageSource FontFamily="MaterialOutlined" Glyph="{x:Static m:MaterialOutlined.Grade}" Size="40" 
                                           Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                        </Button.ImageSource>
                    </Button>
                </Frame>
                
                <Frame Grid.Row="2" Grid.Column="0" Padding="0" HasShadow="True" CornerRadius="15" 
                       BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                    <Button Text="Holidays" Command="{Binding NavigateToHolidaysCommand}" 
                            BackgroundColor="Transparent" 
                            TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" 
                            HeightRequest="100" CornerRadius="15">
                        <Button.ImageSource>
                            <FontImageSource FontFamily="MaterialOutlined" Glyph="{x:Static m:MaterialOutlined.Event}" Size="40" 
                                           Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                        </Button.ImageSource>
                    </Button>
                </Frame>
                
                <Frame Grid.Row="2" Grid.Column="1" Padding="0" HasShadow="True" CornerRadius="15">
                    <Button Text="Logout" Command="{Binding LogoutCommand}" BackgroundColor="#EF5350" TextColor="White" 
                            HeightRequest="100" CornerRadius="15">
                        <Button.ImageSource>
                            <FontImageSource FontFamily="MaterialOutlined" Glyph="{x:Static m:MaterialOutlined.Logout}" Size="40" Color="White"/>
                        </Button.ImageSource>
                    </Button>
                </Frame>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
