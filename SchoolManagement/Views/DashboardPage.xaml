<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SchoolManagement.Views.DashboardPage"
             Title="Dashboard">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="{Binding UserName, StringFormat='Welcome, {0}'}" FontSize="24" FontAttributes="Bold"/>
            
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10" Margin="0,20,0,0">
                <Button Grid.Row="0" Grid.Column="0" Text="Students" Command="{Binding NavigateToStudentsCommand}"/>
                <Button Grid.Row="0" Grid.Column="1" Text="Faculties" Command="{Binding NavigateToFacultiesCommand}"/>
                <Button Grid.Row="1" Grid.Column="0" Text="Attendance" Command="{Binding NavigateToAttendanceCommand}"/>
                <Button Grid.Row="1" Grid.Column="1" Text="Marks" Command="{Binding NavigateToMarksCommand}"/>
                <Button Grid.Row="2" Grid.Column="0" Text="Holidays" Command="{Binding NavigateToHolidaysCommand}"/>
                <Button Grid.Row="2" Grid.Column="1" Text="Logout" Command="{Binding LogoutCommand}" BackgroundColor="Red"/>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
