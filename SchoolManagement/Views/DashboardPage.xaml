<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:m="clr-namespace:UraniumUI.Icons.MaterialIcons;assembly=UraniumUI.Icons.MaterialIcons"
             x:Class="SchoolManagement.Views.DashboardPage"
             Title="Dashboard"
             BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}">
    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="18">
                <Frame BackgroundColor="{StaticResource Primary}" CornerRadius="18" Padding="20" HasShadow="True">
                    <VerticalStackLayout Spacing="8">
                        <HorizontalStackLayout Spacing="12">
                            <Image Source="{FontImageSource FontFamily=MaterialOutlined, Glyph={x:Static m:MaterialOutlined.Account_circle}, Size=48, Color=White}"
                                   HeightRequest="48"
                                   WidthRequest="48" />
                            <VerticalStackLayout>
                                <Label Text="{Binding UserName, StringFormat='Welcome, {0}'}" FontSize="22" FontAttributes="Bold" TextColor="White" />
                                <Label Text="{Binding Role}" FontSize="14" TextColor="White" Opacity="0.9" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                        <Label Text="{Binding SchoolHeader}" FontSize="16" TextColor="White" />
                        <Label Text="{Binding SummaryText}" FontSize="14" TextColor="White" Opacity="0.85" />
                    </VerticalStackLayout>
                </Frame>

                <CollectionView ItemsSource="{Binding Metrics}" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="2" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Margin="0,0,0,10" Padding="14" CornerRadius="16"
                                   BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding Label}" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                                    <Label Text="{Binding Value}" FontSize="22" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}" />
                                    <Label Text="{Binding Hint}" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Frame Padding="16" CornerRadius="16"
                       BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Recommended actions" FontAttributes="Bold" FontSize="18" />
                        <CollectionView ItemsSource="{Binding Highlights}" SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <VerticalStackLayout Spacing="2" Margin="0,0,0,10">
                                        <Label Text="{Binding Title}" FontAttributes="Bold" />
                                        <Label Text="{Binding Description}" FontSize="13"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <VerticalStackLayout IsVisible="{Binding IsOwner}" Spacing="12">
                    <HorizontalStackLayout Spacing="12">
                        <Button Text="Onboard School" Command="{Binding AddSchoolCommand}" HorizontalOptions="FillAndExpand" />
                        <Button Text="Enable / Disable" Command="{Binding ToggleSchoolStatusCommand}" HorizontalOptions="FillAndExpand" BackgroundColor="#0F766E" />
                    </HorizontalStackLayout>
                    <Label Text="Schools" FontAttributes="Bold" FontSize="18" />
                    <CollectionView ItemsSource="{Binding Schools}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Margin="0,0,0,10" Padding="16" CornerRadius="16"
                                       BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="{Binding SchoolName}" FontAttributes="Bold" FontSize="16" />
                                        <Label Text="{Binding SchoolCode, StringFormat='Code: {0}'}" />
                                        <Label Text="{Binding ContactPersonName, StringFormat='Contact: {0}'}" />
                                        <Label Text="{Binding Email}" />
                                        <Label Text="{Binding IsActive, StringFormat='Active: {0}'}" />
                                        <Label Text="{Binding StudentCount, StringFormat='Students: {0}'}" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding IsSchoolAdmin}" Spacing="12">
                    <HorizontalStackLayout Spacing="12">
                        <Button Text="Create Class" Command="{Binding AddClassCommand}" HorizontalOptions="FillAndExpand" />
                        <Button Text="Add Faculty" Command="{Binding AddFacultyCommand}" HorizontalOptions="FillAndExpand" BackgroundColor="#2563EB" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="12">
                        <Button Text="Admit Student + Parent" Command="{Binding AddStudentCommand}" HorizontalOptions="FillAndExpand" BackgroundColor="#0F766E" />
                        <Button Text="Add Holiday" Command="{Binding AddHolidayCommand}" HorizontalOptions="FillAndExpand" BackgroundColor="#D97706" />
                    </HorizontalStackLayout>

                    <Label Text="Classes" FontAttributes="Bold" FontSize="18" />
                    <CollectionView ItemsSource="{Binding Classes}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Margin="0,0,0,10" Padding="16" CornerRadius="16"
                                       BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Name, StringFormat='Class {0}'}" FontAttributes="Bold" />
                                        <Label Text="{Binding Section, StringFormat='Section: {0}'}" />
                                        <Label Text="{Binding StudentCount, StringFormat='Students: {0}'}" />
                                        <Label Text="{Binding Capacity, StringFormat='Capacity: {0}'}" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label Text="Faculty" FontAttributes="Bold" FontSize="18" />
                    <CollectionView ItemsSource="{Binding FacultyMembers}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Margin="0,0,0,10" Padding="16" CornerRadius="16"
                                       BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding FullName}" FontAttributes="Bold" />
                                        <Label Text="{Binding Username, StringFormat='Username: {0}'}" />
                                        <Label Text="{Binding Department}" />
                                        <Label Text="{Binding EmployeeId, StringFormat='Employee ID: {0}'}" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label Text="Students" FontAttributes="Bold" FontSize="18" />
                    <CollectionView ItemsSource="{Binding Students}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Margin="0,0,0,10" Padding="16" CornerRadius="16"
                                       BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding FullName}" FontAttributes="Bold" />
                                        <Label Text="{Binding Username, StringFormat='Username: {0}'}" />
                                        <Label Text="{Binding RollNumber, StringFormat='Roll: {0}'}" />
                                        <Label Text="{Binding Class, StringFormat='Class: {0}'}" />
                                        <Label Text="{Binding ParentName, StringFormat='Parent: {0}'}" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label Text="Holiday Calendar" FontAttributes="Bold" FontSize="18" />
                    <CollectionView ItemsSource="{Binding Holidays}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Margin="0,0,0,10" Padding="16" CornerRadius="16"
                                       BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" />
                                        <Label Text="{Binding Date, StringFormat='Date: {0:dd MMM yyyy}'}" />
                                        <Label Text="{Binding Description}" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding IsFaculty}" Spacing="12">
                    <Label Text="Assigned / Visible Classes" FontAttributes="Bold" FontSize="18" />
                    <CollectionView ItemsSource="{Binding Classes}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Margin="0,0,0,10" Padding="16" CornerRadius="16"
                                       BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Name, StringFormat='Class {0}'}" FontAttributes="Bold" />
                                        <Label Text="{Binding Section, StringFormat='Section: {0}'}" />
                                        <Label Text="{Binding StudentCount, StringFormat='Students: {0}'}" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label Text="Student Directory" FontAttributes="Bold" FontSize="18" />
                    <CollectionView ItemsSource="{Binding Students}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Margin="0,0,0,10" Padding="16" CornerRadius="16"
                                       BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding FullName}" FontAttributes="Bold" />
                                        <Label Text="{Binding Class, StringFormat='Class: {0}'}" />
                                        <Label Text="{Binding Section, StringFormat='Section: {0}'}" />
                                        <Label Text="{Binding RollNumber, StringFormat='Roll: {0}'}" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding IsParent}" Spacing="12">
                    <Label Text="My Children" FontAttributes="Bold" FontSize="18" />
                    <CollectionView ItemsSource="{Binding Children}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Margin="0,0,0,10" Padding="16" CornerRadius="16"
                                       BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding StudentName}" FontAttributes="Bold" />
                                        <Label Text="{Binding RollNumber, StringFormat='Roll: {0}'}" />
                                        <Label Text="{Binding ClassName, StringFormat='Class: {0}'}" />
                                        <Label Text="{Binding Section, StringFormat='Section: {0}'}" />
                                        <Label Text="{Binding AttendancePercentage, StringFormat='Attendance: {0}%'}" />
                                        <Label Text="{Binding AverageMarks, StringFormat='Average marks: {0}%'}" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label Text="School Holidays" FontAttributes="Bold" FontSize="18" />
                    <CollectionView ItemsSource="{Binding Holidays}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Margin="0,0,0,10" Padding="16" CornerRadius="16"
                                       BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" />
                                        <Label Text="{Binding Date, StringFormat='Date: {0:dd MMM yyyy}'}" />
                                        <Label Text="{Binding Description}" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding IsStudent}" Spacing="12">
                    <Label Text="Upcoming School Holidays" FontAttributes="Bold" FontSize="18" />
                    <CollectionView ItemsSource="{Binding Holidays}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Margin="0,0,0,10" Padding="16" CornerRadius="16"
                                       BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" />
                                        <Label Text="{Binding Date, StringFormat='Date: {0:dd MMM yyyy}'}" />
                                        <Label Text="{Binding Description}" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <HorizontalStackLayout Spacing="12">
                    <Button Text="Refresh" Command="{Binding RefreshCommand}" HorizontalOptions="FillAndExpand" />
                    <Button Text="Logout" Command="{Binding LogoutCommand}" HorizontalOptions="FillAndExpand" BackgroundColor="#DC2626" />
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <Grid IsVisible="{Binding IsBusy}" BackgroundColor="#80000000">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                <ActivityIndicator IsRunning="{Binding IsBusy}" Color="White" WidthRequest="50" HeightRequest="50" />
                <Label Text="Loading dashboard..." TextColor="White" FontSize="16" FontAttributes="Bold" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
