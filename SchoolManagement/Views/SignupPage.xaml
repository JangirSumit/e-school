<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SchoolManagement.Views.SignupPage"
             Title="School Signup">
    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="15">
            <Label Text="Register Your School" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,0,0,20"/>
            
            <Label Text="School Information" FontAttributes="Bold"/>
            <Entry Placeholder="School Name *" Text="{Binding SchoolName}"/>
            <Entry Placeholder="Email *" Text="{Binding Email}" Keyboard="Email"/>
            <Entry Placeholder="Phone" Text="{Binding Phone}" Keyboard="Telephone"/>
            <Entry Placeholder="Address" Text="{Binding Address}"/>
            
            <Label Text="Admin Account" FontAttributes="Bold" Margin="0,10,0,0"/>
            <Entry Placeholder="Admin Name" Text="{Binding AdminName}"/>
            <Entry Placeholder="Password *" Text="{Binding Password}" IsPassword="True"/>
            
            <Button Text="Sign Up" Command="{Binding SignupCommand}" Margin="0,20,0,0"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
