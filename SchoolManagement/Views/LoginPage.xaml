<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
             xmlns:m="clr-namespace:UraniumUI.Icons.MaterialIcons;assembly=UraniumUI.Icons.MaterialIcons"
             x:Class="SchoolManagement.Views.LoginPage"
             Shell.NavBarIsVisible="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ScrollView>
            <VerticalStackLayout Padding="24" Spacing="20">
                <Border StrokeThickness="0" BackgroundColor="{StaticResource White}" Padding="0" StrokeShape="RoundRectangle 30">
                    <Grid RowDefinitions="Auto,Auto" Padding="0">
                        <Border StrokeThickness="0" BackgroundColor="{StaticResource Secondary}" Padding="24" StrokeShape="RoundRectangle 30,30,0,0">
                            <VerticalStackLayout Spacing="12">
                                <Frame HeightRequest="74" WidthRequest="74" CornerRadius="37" BackgroundColor="{StaticResource White}" Padding="0" HasShadow="False" HorizontalOptions="Start">
                                    <Image Source="{FontImageSource FontFamily=MaterialOutlined, Glyph={x:Static m:MaterialOutlined.School}, Size=42, Color={StaticResource Primary}}"
                                           HeightRequest="42"
                                           WidthRequest="42"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Frame>
                                <Label Text="{Binding AppName}" FontSize="34" FontAttributes="Bold" TextColor="{StaticResource Gray900}" />
                                <Label Text="{Binding Tagline}" FontSize="15" TextColor="{StaticResource Gray600}" />
                                <Border StrokeThickness="0" BackgroundColor="{StaticResource Sunshine}" Padding="14" StrokeShape="RoundRectangle 18">
                                    <Label Text="{Binding HelpMessage}" FontSize="14" TextColor="{StaticResource Gray900}" LineBreakMode="WordWrap" />
                                </Border>
                            </VerticalStackLayout>
                        </Border>

                        <VerticalStackLayout Grid.Row="1" Padding="24" Spacing="16">
                            <Label Text="Welcome back" FontSize="24" FontAttributes="Bold" />
                            <Label Text="{Binding LoginHint}" FontSize="14" TextColor="{StaticResource Gray600}" />

                            <material:TextField Title="Email or SCHOOLCODE@username" Text="{Binding Email}" Keyboard="Email">
                                <material:TextField.Icon>
                                    <FontImageSource FontFamily="MaterialRegular" Glyph="{x:Static m:MaterialRegular.Person}" Color="{StaticResource Primary}" />
                                </material:TextField.Icon>
                            </material:TextField>

                            <material:TextField Title="Password" Text="{Binding Password}" IsPassword="True">
                                <material:TextField.Icon>
                                    <FontImageSource FontFamily="MaterialRegular" Glyph="{x:Static m:MaterialRegular.Lock}" Color="{StaticResource Primary}" />
                                </material:TextField.Icon>
                            </material:TextField>

                            <Button Text="Login" Command="{Binding LoginCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                                    HeightRequest="52" CornerRadius="18" />

                            <Border StrokeThickness="1" Stroke="{StaticResource Gray200Brush}" BackgroundColor="#FFFDF6" Padding="16" StrokeShape="RoundRectangle 18">
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="School onboarding and billing" FontAttributes="Bold" FontSize="16" />
                                    <Label Text="Schools are onboarded only by the app owner after pricing and billing discussion." FontSize="14" TextColor="{StaticResource Gray600}" />
                                    <Label Text="{Binding SupportEmail, StringFormat='Email: {0}'}" FontSize="14" TextColor="{StaticResource Gray600}" />
                                    <Label Text="{Binding SupportPhone, StringFormat='Call: {0}'}" FontSize="14" TextColor="{StaticResource Gray600}" />
                                    <Label Text="{Binding SupportWhatsApp, StringFormat='WhatsApp: {0}'}" FontSize="14" TextColor="{StaticResource Gray600}" />
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <Grid IsVisible="{Binding IsBusy}" BackgroundColor="#66000000">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
                <ActivityIndicator IsRunning="{Binding IsBusy}" Color="White" WidthRequest="48" HeightRequest="48" />
                <Label Text="Signing in..." TextColor="White" FontSize="16" FontAttributes="Bold" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
