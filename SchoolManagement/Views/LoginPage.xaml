<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
             xmlns:m="clr-namespace:UraniumUI.Icons.MaterialIcons;assembly=UraniumUI.Icons.MaterialIcons"
             x:Class="SchoolManagement.Views.LoginPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Gray100}">
    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="25" VerticalOptions="Center">
            <Image Source="{FontImageSource FontFamily=MaterialOutlined, Glyph={x:Static m:MaterialOutlined.School}, Size=80, Color={StaticResource Primary}}" 
                   HeightRequest="80" Margin="0,0,0,20"/>
            <Label Text="eSchool" FontSize="36" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource Primary}"/>
            <Label Text="Login to your account" FontSize="16" HorizontalOptions="Center" TextColor="{StaticResource Gray600}" Margin="0,0,0,30"/>
            
            <material:TextField Title="Email" Text="{Binding Email}" Keyboard="Email">
                <material:TextField.Icon>
                    <FontImageSource FontFamily="MaterialRegular" Glyph="{x:Static m:MaterialRegular.Email}" Color="{StaticResource Primary}"/>
                </material:TextField.Icon>
            </material:TextField>
            
            <material:TextField Title="Password" Text="{Binding Password}" IsPassword="True">
                <material:TextField.Icon>
                    <FontImageSource FontFamily="MaterialRegular" Glyph="{x:Static m:MaterialRegular.Lock}" Color="{StaticResource Primary}"/>
                </material:TextField.Icon>
            </material:TextField>
            
            <Button Text="Login" Command="{Binding LoginCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" 
                    HeightRequest="50" CornerRadius="25" Margin="0,10,0,0"/>
            <Button Text="Sign Up School" Command="{Binding SignupCommand}" BackgroundColor="Transparent" 
                    TextColor="{StaticResource Primary}" FontAttributes="Bold"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
